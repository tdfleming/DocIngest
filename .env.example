# MinIO (S3-compatible blob storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=docingest

# FastEmbed (local embeddings)
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# Reranking (local cross-encoder, ONNX via FastEmbed; ~80MB, downloaded on first use)
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# MongoDB
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=docingest

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis
REDIS_URL=redis://redis:6379

# Processing
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_PERCENT=10
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=100

# Rate Limiting
DEFAULT_RATE_LIMIT=100

# API
API_HOST=0.0.0.0
API_PORT=8000

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Self-serve signup (POST /v1/auth/signup). OFF by default; enable for a
# multi-tenant / managed deployment where anyone may create an org.
SIGNUP_ENABLED=false

# Telemetry (opt-in, anonymous). OFF by default. When true, sends a periodic
# heartbeat (instance id, version, OS, coarse doc-count bucket) — never content.
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=https://telemetry.docingest.dev/v1/heartbeat
TELEMETRY_INTERVAL_HOURS=24

# Graph RAG
GRAPH_RAG_ENABLED=false
SPACY_MODEL=en_core_web_lg
